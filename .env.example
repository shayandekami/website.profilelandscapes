# ---------- Database ----------
# Local Postgres (docker compose up -d brings this up):
DATABASE_URL="postgres://pl:pl_local_dev@localhost:5433/pl_web"

# When deploying to Vercel + Neon, replace with the Neon connection string.

# ---------- Auth ----------
# Generate with:  openssl rand -base64 32
AUTH_SECRET="change-me-to-a-32-byte-random-string"
AUTH_URL="http://localhost:3000"

# Microsoft Entra ID (Azure AD) — optional. Leave blank to disable SSO.
# When set, a "Sign in with Microsoft" button appears on /admin/login.
# Your Azure app registration must list http://localhost:3000/api/auth/callback/microsoft-entra-id
# as a redirect URI (plus your production URL when deployed).
AZURE_CLIENT_ID=""
AZURE_CLIENT_SECRET=""
AZURE_TENANT_ID=""

# ---------- Theme ----------
# Which theme to render the public site with.
# Themes live in /themes/<name>/  — currently: profile-landscapes
THEME="profile-landscapes"

# ---------- Email ----------
# Without RESEND_API_KEY, quote notifications log to the console (good for dev).
# When ready: sign up at resend.com, verify your domain, paste the API key.
RESEND_API_KEY=""
QUOTE_NOTIFY_EMAIL="carlo@profilelandscapes.com.au"
QUOTE_FROM_EMAIL="Profile Landscapes <studio@profilelandscapes.com.au>"

# ---------- Stripe (Commerce) ----------
# Sign up at stripe.com, get keys from Dashboard → Developers → API keys.
# Test keys start with sk_test_ / pk_test_ — safe for development.
# Live keys start with sk_live_ / pk_live_ — use only in production.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
# Used to build redirect URLs for Stripe checkout (no trailing slash)
NEXT_PUBLIC_URL="http://localhost:3000"
# Public key exposed to the browser (for Stripe.js)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# ---------- Order notifications ----------
# Email address that receives new order confirmations
ORDER_NOTIFY_EMAIL=""
